{
  "name": "bp-correlation",
  "version": "1.0.0",
  "description": "Personal health correlation app — correlates wearable data with food and hydration logs",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"nodemon server.js\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "install:all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "@parse/node-apn": "^7.1.0",
    "axios": "^1.7.2",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.4"
  }
}
